---
import ScreenDesignFullscreen from '@/components/ScreenDesignFullscreen.astro'
import { getScreenDesignPaths } from '@/lib/astro-route-paths'

export async function getStaticPaths() {
  const screenDesignPaths = await getScreenDesignPaths()
  return screenDesignPaths.map(({ sectionId, screenDesignName }) => ({
    params: { sectionId, screenDesignName },
  }))
}
---

<ScreenDesignFullscreen />
